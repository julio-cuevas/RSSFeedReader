@page "/"
@using RSSFeedReader.UI.Models
@inject HttpClient Http

<PageTitle>Subscriptions</PageTitle>

<h1>RSS Subscriptions</h1>

<div class="mb-3">
    <label for="feedUrl" class="form-label">Feed URL</label>
    <input id="feedUrl" class="form-control" @bind="newFeedUrl" placeholder="Enter RSS or Atom feed URL" />
    <button class="btn btn-primary mt-2" @onclick="AddSubscription">Add Subscription</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (subscriptions is null)
{
    <p>Loading subscriptions...</p>
}
else if (!subscriptions.Any())
{
    <div class="alert alert-secondary">No subscriptions added yet.</div>
}
else
{
    <ul class="list-group">
        @foreach (var subscription in subscriptions)
        {
            <li class="list-group-item">@subscription.FeedUrl</li>
        }
    </ul>
}

@code {
    private string newFeedUrl = string.Empty;
    private string errorMessage = string.Empty;
    private List<Subscription>? subscriptions;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptionsAsync();
    }

    private async Task AddSubscription()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(newFeedUrl))
        {
            errorMessage = "Please enter a feed URL.";
            return;
        }

        var subscription = new Subscription { FeedUrl = newFeedUrl.Trim() };
        var response = await Http.PostAsJsonAsync("subscriptions", subscription);

        if (response.IsSuccessStatusCode)
        {
            newFeedUrl = string.Empty;
            await LoadSubscriptionsAsync();
        }
        else
        {
            var error = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
            errorMessage = error?.GetValueOrDefault("error") ?? "Failed to add subscription.";
        }
    }

    private async Task LoadSubscriptionsAsync()
    {
        subscriptions = await Http.GetFromJsonAsync<List<Subscription>>("subscriptions");
    }
}
